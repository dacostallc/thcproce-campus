generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum AccessStatus {
  pendente
  ativo
  expirado
  vitalicio
}

/// Papéis para CMS/admin futuro; o campus existente não depende disto ainda.
enum UserRole {
  STUDENT
  ADMIN
}

enum PublishStatus {
  DRAFT
  PUBLISHED
}

enum BlockType {
  HEADING
  PARAGRAPH
  CALLOUT
  IMAGE
  VIDEO_EMBED
  FILE_DOWNLOAD
  QUIZ_EMBED
  CUSTOM
}

enum AvatarItemType {
  HAT
  BADGE
}

enum MissionType {
  COMPLETE_QUIZ
  PASS_QUIZ
  EARN_XP
  UNLOCK_ACHIEVEMENT
}

model Profile {
  id           String   @id @default(cuid())
  email        String?  @unique
  displayName  String?
  /// Tipo de avatar simbólico (valores fixos da app, ex.: menino, cultivador).
  avatarType  String?
  /// Cor de destaque do avatar (ex.: verde, dourado).
  avatarColor String?
  moodleUserId Int?     @unique
  xpTotal      Int      @default(0)
  /// Créditos simbólicos (“souvenirs”) — sem valor monetário; futuras recompensas da escola.
  souvenirCredits Int @default(0)
  levelKey     String   @default("semente")
  streakDays   Int      @default(0)
  lastActive   DateTime @default(now())
  /// Idempotência de recompensas (XP/souvenirs, chaves por dia UTC, etc.) — ver `src/lib/progression/claims.ts`.
  progressionClaims Json @default("{}")
  // Progresso de aulas ({ [slug]: number[] }) em JSON texto
  lessonProgress String @default("{}")
  // Hash bcrypt (credenciais). OAuth pode deixar vazio.
  passwordHash   String?
  whatsapp       String?
  cpf            String?
  country        String?
  city           String?
  stateRegion    String?
  // Plano escolhido: ids em src/config/enrollmentPlans.ts
  selectedPlanId String?
  accessStatus     AccessStatus @default(pendente)
  termsAcceptedAt  DateTime?
  // Checkout futuro: pix, stripe, mercadopago...
  preferredCheckoutProvider String?
  // Fila Moodle quando WS ativo
  moodleSyncPending Boolean @default(false)
  role              UserRole @default(STUDENT)
  /// Presença social no campus: nome público | anónimo | invisível (`src/types/campusSocialPresence.ts`).
  campusSocialVisibility  String @default("name")
  /// Estado leve mostrado no cartão social (exploring | studying | cinema | rest).
  campusSocialStatusLight String @default("exploring")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  /// Código curto único para convites (normalizado em maiúsculas na app).
  referralCode              String? @unique
  referredByProfileId       String?
  referredBy                Profile?  @relation("ProfileReferralParent", fields: [referredByProfileId], references: [id], onDelete: SetNull)
  invitedProfiles           Profile[] @relation("ProfileReferralParent")
  /// Créditos souvenir simbólicos ganhos por indicações concluídas (não confundir com souvenirCredits total).
  referralSouvenirEarned    Int       @default(0)

  referralsAsReferrer       Referral[] @relation("ReferralReferrer")
  referralReceived          Referral?  @relation("ReferralReferred")

  /// Histórico simples de recompensas (XP, souvenirs, eventos).
  rewardLogs                ProfileRewardLog[]

  activeHatItemId   String?
  activeHatItem     AvatarItem? @relation("ProfileActiveHat", fields: [activeHatItemId], references: [id], onDelete: SetNull)
  activeBadgeItemId String?
  activeBadgeItem   AvatarItem? @relation("ProfileActiveBadge", fields: [activeBadgeItemId], references: [id], onDelete: SetNull)

  quizAttempts      QuizAttempt[]
  userAchievements  UserAchievement[]
  userAvatarItems   UserAvatarItem[]
  userMissionProgresses UserMissionProgress[]

  /// THCProce Campus — estado persistente do mapa e microaulas (Fase A).
  userCampusProgress      UserCampusProgress?
  userZoneDiscoveries     UserZoneDiscovery[]
  userMicroLessonProgress UserMicroLessonProgress[]
  campusXpLedger          UserXpLedger[]
  campusBadges            UserBadge[]
  campusMissionProgress   CampusMissionProgress[]
  campusSocialPresence    CampusSocialPresence?
  /// Progresso relacional por curso/área — fonte canónica para novas áreas; complementa lessonProgress JSON.
  courseProgresses        UserCourseProgress[]
  examAttempts            UserExamAttempt[]
  certificates            Certificate[]
}

/// Sessão de presença social leve no campus (polling; renovada por heartbeat).
model CampusSocialPresence {
  profileId            String   @id
  profile              Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  /// Espelho da preferência no momento do último heartbeat (para filtrar em poll sem join extra).
  visibilitySnapshot   String   @default("name")
  statusLight          String   @default("exploring")
  currentZoneLabel     String?
  avatarUrl            String?
  displayNameSnapshot  String?
  peerToken            String   @unique
  lastSeenAt           DateTime @updatedAt
  createdAt            DateTime @default(now())

  @@index([lastSeenAt])
  @@index([currentZoneLabel, lastSeenAt])
}

/// Interacções pré-aprovadas (sem texto livre). TTL limpo no poll.
model CampusSocialGesture {
  id            String   @id @default(cuid())
  fromProfileId String
  toProfileId   String
  kind          String
  emoji         String?
  createdAt     DateTime @default(now())

  @@index([toProfileId, createdAt])
  @@index([fromProfileId, createdAt])
}

/// Progresso das orientações / primeiros passos no campus (catálogo em `src/lib/campus/campusMissions.ts`).
model CampusMissionProgress {
  profileId       String
  missionId       String
  profile         Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  progressCurrent Int       @default(0)
  completedAt     DateTime?
  rewardClaimedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@id([profileId, missionId])
  @@index([profileId])
}

/// Memória do campus: última zona, painéis e histórico leve (JSON).
model UserCampusProgress {
  profileId String  @id
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  lastZoneLabel              String?
  lastLegacyHitId            String?
  lastBuildingCourseId       String?
  lastMicroLessonBlueprintId String?
  /// course | hotspot | lesson | null
  lastPanelKind              String?

  recommendedZoneLabels Json @default("[]")
  favoriteTrailIds      Json @default("[]")
  navigationHistory     Json @default("[]")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserZoneDiscovery {
  id        String   @id @default(cuid())
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  zoneLabel String
  status    String   @default("discovered")
  visitCount Int     @default(1)
  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())

  @@unique([profileId, zoneLabel])
  @@index([profileId])
}

model UserMicroLessonProgress {
  id             String    @id @default(cuid())
  profileId      String
  profile        Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  blueprintId    String
  zoneLabel      String
  legacyHitId    String?
  startedAt      DateTime?
  completedAt    DateTime?
  xpEarned       Int       @default(0)
  secondsEngaged Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([profileId, blueprintId])
  @@index([profileId, zoneLabel])
}

/// Ledger de XP ganho no campus (microaulas, zonas, painéis). Não duplica `ProfileRewardLog`.
model UserXpLedger {
  id        String   @id @default(cuid())
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  actionType String
  amount    Int
  meta      Json?

  createdAt DateTime @default(now())

  @@index([profileId, createdAt])
}

/// Badges específicos do ecossistema Campus (separados de Achievement Moodle/legacy).
model UserBadge {
  id        String   @id @default(cuid())
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  badgeCode String
  unlockedAt DateTime @default(now())

  @@unique([profileId, badgeCode])
  @@index([profileId])
}

/// Progresso do aluno por curso/área — uma linha por (perfil, slug do curso).
/// Estratégia de migração:
///  - Profile.lessonProgress (JSON legado) é mantido para retrocompatibilidade.
///  - Novas escritas (lessonMarkSeen) gravam em AMBOS; leituras fazem merge,
///    com UserCourseProgress tendo precedência por slug.
///  - Quando um novo curso é criado (ex.: "extracoes-101"), o progresso nasce aqui,
///    independente do JSON legado.
model UserCourseProgress {
  id        String  @id @default(cuid())
  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  /// Slug canónico da área/curso no campus (ex.: "cannabis-101", "extracoes-101").
  /// Corresponde a `Area.id` em `src/data/courses.ts` e ao slug do `Course` no CMS.
  courseSlug String

  /// Índices 0-based das aulas marcadas como concluídas — JSON array de inteiros.
  /// Ex.: [0, 1, 3] = aulas 1, 2 e 4 concluídas.
  completedLessonIndices Json @default("[]")

  /// Última aula acedida (0-based). Usado para retomar onde parou.
  lastLessonIndex Int?

  startedAt    DateTime  @default(now())
  /// Actualizado automaticamente a cada upsert de lessonMarkSeen.
  lastAccessAt DateTime  @updatedAt
  /// Preenchido quando todos os índices publicados estão concluídos.
  completedAt  DateTime?

  @@unique([profileId, courseSlug])
  @@index([profileId])
  @@index([courseSlug])
}

/// Áudio narrado de uma aula — gerado via ElevenLabs e armazenado externamente (Supabase Storage / CDN).
/// Uma linha por (courseId, lessonId); o script `generate-lesson-audio.mts` preenche os registos.
/// Se `audioUrl` estiver vazio, o player não aparece para o aluno.
model LessonAudio {
  id          String   @id @default(cuid())
  /// Slug do curso (ex.: "cannabis-101"). Igual ao courseId em course.json.
  courseId    String
  /// Id estável da aula (ex.: "c101-l05-escolha-local-cultivo"). Igual ao nome do .md sem extensão.
  lessonId    String
  /// URL pública do MP3 (Supabase Storage, Vercel Blob, CDN ou /audio/lessons/…).
  audioUrl    String
  /// Duração em segundos (preenchida pelo script após gerar o áudio).
  durationSec Int?
  /// Tamanho do ficheiro em bytes.
  sizeBytes   Int?
  generatedAt DateTime @default(now())

  @@unique([courseId, lessonId])
  @@index([courseId])
}

// ─── Sistema de Provas e Certificados ────────────────────────────────────────

/// Prova de um curso ou aula específica — perguntas em JSON.
/// lessonId null = prova final do curso completo.
model Exam {
  id        String   @id @default(cuid())
  /// Slug do curso (ex.: "extracoes-101", "cannabis-101").
  courseId  String
  /// Id estável da aula (opcional — null = prova final do curso).
  lessonId  String?
  title     String
  /// Array de { question: string, options: string[], correct: number (índice 0-based) }
  questions Json
  /// Nota mínima para aprovação (0–10). Padrão: 7.
  passingScore Float   @default(7.0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  attempts  UserExamAttempt[]

  @@unique([courseId, lessonId])
  @@index([courseId])
}

/// Tentativa de prova — uma linha por (aluno, prova, tentativa).
model UserExamAttempt {
  id         String   @id @default(cuid())
  profileId  String
  profile    Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  examId     String
  exam       Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  /// Nota de 0 a 10.
  score      Float
  /// Respostas do aluno — array de índices (ex.: [0, 2, 1]).
  answers    Json
  /// Calculado na app: score >= exam.passingScore.
  isApproved Boolean
  createdAt  DateTime @default(now())

  @@index([profileId, examId])
}

/// Certificado emitido automaticamente quando o aluno é aprovado.
/// verifyHash é o token público de verificação (URL /certificado/<hash>).
model Certificate {
  id          String   @id @default(cuid())
  profileId   String
  profile     Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  /// Slug do curso certificado.
  courseId    String
  /// Hash público único para verificação externa.
  verifyHash  String   @unique @default(cuid())
  issuedAt    DateTime @default(now())

  @@unique([profileId, courseId])
  @@index([profileId])
}

/// Registo idempotente: um perfil só pode receber bónus de indicação uma vez (referredProfileId único).
model Referral {
  id                   String   @id @default(cuid())
  referrerProfileId    String
  referredProfileId    String   @unique
  referrerRewardAmount Int
  referredRewardAmount Int
  createdAt            DateTime @default(now())

  referrer Profile @relation("ReferralReferrer", fields: [referrerProfileId], references: [id], onDelete: Cascade)
  referred Profile @relation("ReferralReferred", fields: [referredProfileId], references: [id], onDelete: Cascade)

  @@index([referrerProfileId])
}

/// Linha de histórico de recompensas por perfil (auditoria simples para o aluno).
model ProfileRewardLog {
  id                    String   @id @default(cuid())
  profileId             String
  profile               Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  /// Código estável: QUIZ_PASS, ACHIEVEMENT_UNLOCK, MISSION_COMPLETE, REFERRAL_REFERRER, REFERRAL_RECIPIENT, COSMETIC_UNLOCK
  type                  String
  /// Origem curta opcional (quizId, código missão, código item, etc.)
  source                String?
  description           String
  xpAmount              Int      @default(0)
  souvenirCreditsAmount Int      @default(0)
  createdAt             DateTime @default(now())

  @@index([profileId, createdAt])
}

/// Item cosmético fixo (sem loja); desbloqueado por código de Achievement.
model AvatarItem {
  id                      String         @id @default(cuid())
  code                    String         @unique
  name                    String
  description             String?
  type                    AvatarItemType
  displayGlyph            String         @default("✨")
  /// Código opcional do `Achievement` que desbloqueia este item.
  unlockAchievementCode String?
  active                  Boolean        @default(true)

  unlockedBy         UserAvatarItem[]
  profilesAsActiveHat   Profile[] @relation("ProfileActiveHat")
  profilesAsActiveBadge Profile[] @relation("ProfileActiveBadge")
}

model UserAvatarItem {
  profileId    String
  avatarItemId String
  profile      Profile    @relation(fields: [profileId], references: [id], onDelete: Cascade)
  avatarItem   AvatarItem @relation(fields: [avatarItemId], references: [id], onDelete: Cascade)
  unlockedAt   DateTime   @default(now())

  @@id([profileId, avatarItemId])
  @@index([profileId])
}

model Mission {
  id                    String      @id @default(cuid())
  code                  String      @unique
  title                 String
  description           String?
  type                  MissionType
  targetValue           Int         @default(1)
  xpReward              Int         @default(0)
  souvenirCreditsReward Int         @default(0)
  sortOrder             Int         @default(0)
  active                Boolean     @default(true)

  progresses UserMissionProgress[]
}

model UserMissionProgress {
  profileId       String
  missionId       String
  profile         Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  mission         Mission   @relation(fields: [missionId], references: [id], onDelete: Cascade)
  currentProgress Int       @default(0)
  completedAt     DateTime?

  @@id([profileId, missionId])
  @@index([profileId])
}

model ChatMessage {
  id          String   @id @default(cuid())
  channel     String
  authorId    String?
  authorName  String
  body        String
  createdAt   DateTime @default(now())
}

model Subscription {
  id         String    @id @default(cuid())
  profileId  String
  plan       String
  startsAt   DateTime  @default(now())
  endsAt     DateTime?
  externalId String?
  createdAt  DateTime  @default(now())
}

// --- Campus CMS (MVP): conteúdo versionado em DB; leitura pública ainda não ligada nas rotas. ---

model Course {
  id           String        @id @default(cuid())
  slug         String        @unique
  title        String
  description  String?
  thumbnailUrl String?
  status       PublishStatus @default(DRAFT)
  sortOrder    Int           @default(0)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  modules Module[]
}

model Module {
  id          String        @id @default(cuid())
  courseId    String
  course      Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  slug        String
  title       String
  description String?
  status      PublishStatus @default(DRAFT)
  sortOrder   Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  lessons Lesson[]

  @@unique([courseId, slug])
  @@index([courseId, sortOrder])
}

model Lesson {
  id        String        @id @default(cuid())
  moduleId  String
  module    Module        @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  slug      String
  title     String
  status    PublishStatus @default(DRAFT)
  sortOrder Int           @default(0)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  blocks ContentBlock[]
  quizzes Quiz[]

  @@unique([moduleId, slug])
  @@index([moduleId, sortOrder])
}

model ContentBlock {
  id        String    @id @default(cuid())
  lessonId  String
  lesson    Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  type      BlockType
  sortOrder Int       @default(0)
  data      Json
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([lessonId, sortOrder])
}

model Quiz {
  id             String   @id @default(cuid())
  lessonId       String
  lesson         Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  title          String
  passingPercent Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  questions Question[]
  attempts  QuizAttempt[]

  @@index([lessonId])
}

model Question {
  id          String  @id @default(cuid())
  quizId      String
  quiz        Quiz    @relation(fields: [quizId], references: [id], onDelete: Cascade)
  prompt      String
  type        String
  sortOrder   Int     @default(0)
  explanation String?

  options QuestionOption[]

  @@index([quizId, sortOrder])
}

model QuestionOption {
  id          String   @id @default(cuid())
  questionId  String
  question    Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  label       String
  isCorrect   Boolean  @default(false)
  sortOrder   Int      @default(0)

  @@index([questionId, sortOrder])
}

model QuizAttempt {
  id         String    @id @default(cuid())
  quizId     String
  quiz       Quiz      @relation(fields: [quizId], references: [id], onDelete: Cascade)
  profileId  String
  profile    Profile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  startedAt  DateTime  @default(now())
  finishedAt DateTime?
  score      Int       @default(0)
  maxScore   Int       @default(0)
  passed     Boolean?

  responses QuizResponse[]

  @@index([profileId, quizId])
}

model QuizResponse {
  id            String      @id @default(cuid())
  attemptId     String
  attempt       QuizAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  questionId    String
  value         Json
  isCorrect     Boolean?
  awardedPoints Int         @default(0)

  @@unique([attemptId, questionId])
  @@index([attemptId])
}

model Achievement {
  id          String @id @default(cuid())
  code        String @unique
  title       String
  description String?
  xpReward    Int    @default(0)
  /// Créditos simbólicos extra ao desbloquear (opcional).
  souvenirCredits Int @default(0)

  users UserAchievement[]
}

model UserAchievement {
  profileId     String
  achievementId String
  profile       Profile     @relation(fields: [profileId], references: [id], onDelete: Cascade)
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  unlockedAt    DateTime    @default(now())

  @@id([profileId, achievementId])
}

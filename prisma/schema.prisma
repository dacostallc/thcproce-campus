generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Profile {
  id           String   @id @default(cuid())
  email        String?  @unique
  displayName  String?
  moodleUserId Int?     @unique
  xpTotal      Int      @default(0)
  levelKey     String   @default("semente")
  streakDays   Int      @default(0)
  lastActive   DateTime @default(now())
  // Progresso de aulas ({ [slug]: number[] }) em JSON texto
  lessonProgress String @default("{}")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ChatMessage {
  id          String   @id @default(cuid())
  channel     String
  authorId    String?
  authorName  String
  body        String
  createdAt   DateTime @default(now())
}

model Subscription {
  id         String    @id @default(cuid())
  profileId  String
  plan       String
  startsAt   DateTime  @default(now())
  endsAt     DateTime?
  externalId String?
  createdAt  DateTime  @default(now())
}

# Local: PostgreSQL via Docker (`docker compose up -d`) ou URL da Neon/grátis.
# Produção (Vercel): obrigatório Postgres serverless — nunca SQLite file: neste deploy.
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/thcproce_campus"

NEXT_PUBLIC_MOODLE_BASE_URL=https://thcproce.com.br/escola
MOODLE_WS_TOKEN=
MOODLE_MOCK_USER_ID=
# JSON: slug do campus (courses.ts) → id numérico do curso no Moodle
# MOODLE_COURSE_MAP={"cannabis-101":12}

NEXTAUTH_URL=http://localhost:3030
NEXTAUTH_SECRET=

# Inscrição /login: contas em /inscrever-se guardam hash em DB. Sem cadastro ainda: senha demo.
# CAMPUS_DEMO_PASSWORD=demo

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

SENTRY_AUTH_TOKEN=
NEXT_PUBLIC_SENTRY_DSN=

MUX_TOKEN_ID=
MUX_TOKEN_SECRET=

# Cannabis 101 — stream dedicado (não usa Mux/Bunny demo global até publicar aqui)
# Vídeo principal da sala quando o upload Mux existir:
NEXT_PUBLIC_CANNABIS101_PRIMARY_MUX_PLAYBACK_ID=

# Trailer opcional: botão “Assistir trailer” só aparece se um deles estiver preenchido
NEXT_PUBLIC_CANNABIS101_TRAILER_MUX_PLAYBACK_ID=
NEXT_PUBLIC_CANNABIS101_TRAILER_YOUTUBE_ID=

# Lista Cannabis 101: aulas com índice < N aparecem como disponíveis; demais “Em breve”. Vazio = todas.
NEXT_PUBLIC_CANNABIS101_PUBLISHED_LESSONS=
# true = aula N+1 bloqueada até marcar N como vista
NEXT_PUBLIC_CANNABIS101_SEQUENTIAL_LOCK=
# Ordem: Mux demo → Bunny iframe público (lib+id) → YouTube (só se NEXT_PUBLIC_DEFAULT_DEMO_YOUTUBE_VIDEO_ID) → hero THCProce sem vídeo genérico.
NEXT_PUBLIC_MUX_DEMO_PLAYBACK_ID=

# Bunny só embed público: precisa biblioteca + id do vídeo. Deixe vazio para ignorar Bunny.
NEXT_PUBLIC_BUNNY_LIBRARY_ID=
NEXT_PUBLIC_BUNNY_DEMO_VIDEO_ID=

# YouTube embed só se preencher (ex. trailer THCProce). Vazio = hero cinematográfico no painel, sem vídeo genérico.
NEXT_PUBLIC_DEFAULT_DEMO_YOUTUBE_VIDEO_ID=

NEXT_PUBLIC_LODGER_CHECKOUT=https://thcproce.com.br/escola/lodger/join/subscription.php?productid=2

# Campus / mapa — slugs de `courses.ts` separados por vírgula (ex.: laboratorio,industria)
# NEXT_PUBLIC_CAMPUS_AREAS_CONSTRUCTION=
# true = visitante pode abrir todas as salas sem checar perfil (demo / campus público)
# NEXT_PUBLIC_CAMPUS_PUBLIC_ALL=
# true = perfil "pendente" também abre salas (útil em staging)
# NEXT_PUBLIC_CAMPUS_ALLOW_PENDING_ACCESS=

# Botão "Entrar com Moodle" em /entrar (só se SSO estiver configurado abaixo):
NEXT_PUBLIC_SHOW_MOODLE_LOGIN=false

# SSO OAuth/OIDC (Keycloak, plugin servidor OAuth2 no Moodle, ou IdP externo com discovery):
# MOODLE_OIDC_ISSUER=https://seu-dominio/oauth2/server
# Alternativa: URL completa do discovery
# MOODLE_OIDC_DISCOVERY_URL=
# Sem discovery: preencha autorização + token + userinfo manualmente
# MOODLE_OAUTH_AUTHORIZATION_URL=
# MOODLE_OAUTH_TOKEN_URL=
# MOODLE_OAUTH_USERINFO_URL=
# MOODLE_OAUTH_CLIENT_ID=
# MOODLE_OAUTH_CLIENT_SECRET=
# MOODLE_OAUTH_SCOPES=openid email profile
# MOODLE_OAUTH_PROVIDER_NAME=Moodle THCProce

# Bunny embed assinado — opcional; sem chaves, o campus usa só Mux público/Bunny público/YouTube.
# BUNNY_STREAM_TOKEN_AUTH_KEY=
# BUNNY_STREAM_LIBRARY_ID=

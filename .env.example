# Local: PostgreSQL via Docker — `docker compose up -d` na raiz; detalhes em docs/LOCAL_DATABASE.md
# Produção (Vercel): obrigatório Postgres serverless — nunca SQLite file: neste deploy.
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/thcproce_campus"
# Migrações Prisma / Supabase: URL directa (sessão). Em Postgres local, pode ser igual a DATABASE_URL.
DIRECT_URL="postgresql://postgres:postgres@127.0.0.1:5432/thcproce_campus"
# Vercel Postgres (Storage): o painel cria POSTGRES_PRISMA_URL + POSTGRES_URL_NON_POOLING — a app sincroniza para DATABASE_URL/DIRECT_URL se estes estiverem vazios.

# Piloto CMS: aulas servidas do Postgres no painel do campus (sem mudar URLs).
# Formato: areaId|índice0based|slugCurso|slugMódulo|slugAula — várias entradas separadas por vírgula.
# Ex.: CAMPUS_DB_LESSONS=cannabis-101|0|cannabis-101|intro|boas-vindas
# Checklist manual CMS + gamificação: docs/GAMIFICATION_E2E_CHECKLIST.md
# CAMPUS_DB_LESSONS=

NEXT_PUBLIC_MOODLE_BASE_URL=https://thcproce.com.br/escola
# Base só servidor para WS quando /escola estiver bloqueado no edge mas o Moodle responder por outro host:
# MOODLE_WS_BASE_URL=https://origem-interna-do-moodle/escola
MOODLE_WS_TOKEN=
MOODLE_MOCK_USER_ID=
# JSON: slug do campus (courses.ts) → id numérico do curso no Moodle
# MOODLE_COURSE_MAP={"cannabis-101":12}
#
# Link directo Cannabis 101 no painel do campus (course/view.php?id=…). Obrigatório para botões/textos “Abrir no Moodle”.
NEXT_PUBLIC_MOODLE_CANNABIS101_COURSE_ID=

NEXTAUTH_URL=http://localhost:3030
# Produção: https://thcproce.com.br — mesmo valor em NEXT_PUBLIC_SITE_URL (abaixo).
# Auth.js v5 usa AUTH_URL; com next-auth v4 aqui basta NEXTAUTH_URL consistente com o domínio público.
# AUTH_URL=https://thcproce.com.br
NEXTAUTH_SECRET=

NEXT_PUBLIC_SITE_URL=http://localhost:3030

# Inscrição /login: contas em /inscrever-se guardam hash em DB. Sem cadastro ainda: senha demo.
# CAMPUS_DEMO_PASSWORD=demo

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

SENTRY_AUTH_TOKEN=
NEXT_PUBLIC_SENTRY_DSN=

MUX_TOKEN_ID=
MUX_TOKEN_SECRET=

# Cannabis 101 — stream dedicado (não usa Mux/Bunny demo global até publicar aqui)
# Vídeo principal da sala quando o upload Mux existir:
NEXT_PUBLIC_CANNABIS101_PRIMARY_MUX_PLAYBACK_ID=
# Sala Cannabis 101: embed YouTube (só ID do vídeo) quando Mux principal acima está vazio. Se vazio, usa TRAILER_YOUTUBE_ID abaixo.
NEXT_PUBLIC_CANNABIS101_LESSON_YOUTUBE_ID=

# Trailer opcional: botão “Assistir trailer” só aparece se um deles estiver preenchido
NEXT_PUBLIC_CANNABIS101_TRAILER_MUX_PLAYBACK_ID=
NEXT_PUBLIC_CANNABIS101_TRAILER_YOUTUBE_ID=

# Lista Cannabis 101: aulas com índice < N aparecem como disponíveis; demais “Em breve”. Vazio = todas.
NEXT_PUBLIC_CANNABIS101_PUBLISHED_LESSONS=
# true = aula N+1 bloqueada até marcar N como vista
NEXT_PUBLIC_CANNABIS101_SEQUENTIAL_LOCK=
# Ordem: Mux demo → Bunny iframe público (lib+id) → YouTube (só se NEXT_PUBLIC_DEFAULT_DEMO_YOUTUBE_VIDEO_ID) → hero THCProce sem vídeo genérico.
NEXT_PUBLIC_MUX_DEMO_PLAYBACK_ID=

# Bunny só embed público: precisa biblioteca + id do vídeo. Deixe vazio para ignorar Bunny.
NEXT_PUBLIC_BUNNY_LIBRARY_ID=
NEXT_PUBLIC_BUNNY_DEMO_VIDEO_ID=

# --- Vídeos grandes (ficheiros MP4 no Bunny Storage + Pull Zone CDN) ---
# Base pública da Pull Zone (sem barra final). Os helpers montam `${BASE}/${ficheiro}`.
# Ex.: https://thcproce-media.b-cdn.net/campus-video
NEXT_PUBLIC_CAMPUS_CDN_BASE_URL=
# Opcional: URL completa ou nome do ficheiro na Pull Zone. Vazio = usa CDN + cannabis-sem-mito.mp4 (ou /video só em dev).
NEXT_PUBLIC_CANNABIS101_OPENING_VIDEO_SRC=
# Painel HUD «Cinema e ao vivo» no mapa — mesmo padrão. Vazio explicitamente ("") desliga vídeo no cartão.
NEXT_PUBLIC_CAMPUS_CINEMA_VIDEO_SRC=
# true = permitir servir `/video/*.mp4` a partir de `public/` mesmo fora de NODE_ENV=development (staging com ficheiros locais).
# NEXT_PUBLIC_CAMPUS_MEDIA_ALLOW_LOCAL=

# YouTube embed só se preencher (ex. trailer THCProce). Vazio = hero cinematográfico no painel, sem vídeo genérico.
NEXT_PUBLIC_DEFAULT_DEMO_YOUTUBE_VIDEO_ID=

NEXT_PUBLIC_LODGER_CHECKOUT=
# Quando vazio, os botões de checkout da HUD/planos usam /planos. URL absoluta do Lodger quando voltar a ficar pública.

# Página `/planos`: preços públicos só se preenchidos (evita valores inventados na landing).
# Vazio ou omitido: Visitante mostra «Gratuito»; Aluno «Consultar acesso»; Premium «Em breve».
# Ex.: NEXT_PUBLIC_PLAN_PRICE_ALUNO="A partir de R$ 19,90/mês"
# NEXT_PUBLIC_PLAN_PRICE_VISITANTE=
# NEXT_PUBLIC_PLAN_PRICE_ALUNO=
# NEXT_PUBLIC_PLAN_PRICE_PREMIUM=
# Botão «Consultar assinatura» (Premium): mailto só se definido aqui (senão volta para `/inscrever-se`).
# NEXT_PUBLIC_PLANOS_CONTACT_EMAIL=contato@exemplo.com

# Campus / mapa — slugs de `courses.ts` separados por vírgula (ex.: laboratorio,industria)
# NEXT_PUBLIC_CAMPUS_AREAS_CONSTRUCTION=

# Liberação progressiva de aulas (fora Cannabis 101 — veja CANNABIS101_* acima)
# JSON: slug do curso → número de aulas “publicadas” (restante aparece como Em breve)
# NEXT_PUBLIC_CAMPUS_LESSON_PUBLISHED_MAP={"cultivo-indoor":6}
# Padrão quando o mapa não define o curso (default: 4 primeiras aulas)
# NEXT_PUBLIC_CAMPUS_DEFAULT_PUBLISHED_LESSONS=4
# true = aula N+1 bloqueada até marcar N como vista (Cannabis 101 usa CANNABIS101_SEQUENTIAL_LOCK)
# NEXT_PUBLIC_CAMPUS_SEQUENTIAL_LOCK=
# true = visitante pode abrir todas as salas sem checar perfil (demo / campus público)
# NEXT_PUBLIC_CAMPUS_PUBLIC_ALL=
# true = perfil "pendente" também abre salas (útil em staging)
# NEXT_PUBLIC_CAMPUS_ALLOW_PENDING_ACCESS=

# Evento ao vivo — com NEXT_PUBLIC_CAMPUS_LIVE_ACTIVE=true (Telão/live no mapa):
# - logados abrem salas mesmo pendente/expirado — não é preciso outra variável
# - visitantes sem login também abrem salas pelo mapa (sala lotada ao vivo)
# Imagem do telão (opcional). Vazio = gradiente sem pedido HTTP (evita 404 se o PNG não existir).
# Ex.: sirva em public/campus/cine-tela.png e use:
# NEXT_PUBLIC_CAMPUS_CINE_TELA=/campus/cine-tela.png
# Opcional endurecer só com LIVE ativo: NEXT_PUBLIC_CAMPUS_LIVE_STRICT_GATE=true
# Ou visitantes continuam bloqueados: NEXT_PUBLIC_CAMPUS_LIVE_BLOCK_VISITOR_AREAS=true
# (equivale NEXT_PUBLIC_CAMPUS_LIVE_VISITOR_AREA_ACCESS=false)
# NEXT_PUBLIC_CAMPUS_OPEN_COURSES_DURING_LIVE — legado redundante quando LIVE_ACTIVE já está true

# Bypass total do mapa para e-mails listados (separados por vírgula). Case-insensitive.
# Abre todas as áreas; ignora modal fundador e áreas em construção.
# NEXT_PUBLIC_CAMPUS_ADMIN_EMAILS=admin@example.com,funder@example.com
# QA Campus: revela botão «Resetar progresso local», secções cosméticas técnicas e aviso QA na loja (além do botão sempre visível em `NODE_ENV=development`).
# NEXT_PUBLIC_DEBUG_PROFILE_RESET=true
NEXT_PUBLIC_SHOW_MOODLE_LOGIN=false

# SSO OAuth/OIDC (Keycloak, plugin servidor OAuth2 no Moodle, ou IdP externo com discovery):
# MOODLE_OIDC_ISSUER=https://seu-dominio/oauth2/server
# Alternativa: URL completa do discovery
# MOODLE_OIDC_DISCOVERY_URL=
# Sem discovery: preencha autorização + token + userinfo manualmente
# MOODLE_OAUTH_AUTHORIZATION_URL=
# MOODLE_OAUTH_TOKEN_URL=
# MOODLE_OAUTH_USERINFO_URL=
# MOODLE_OAUTH_CLIENT_ID=
# MOODLE_OAUTH_CLIENT_SECRET=
# MOODLE_OAUTH_SCOPES=openid email profile
# MOODLE_OAUTH_PROVIDER_NAME=Moodle THCProce

# Bunny embed assinado — opcional; sem chaves, o campus usa só Mux público/Bunny público/YouTube.
# BUNNY_STREAM_TOKEN_AUTH_KEY=
# BUNNY_STREAM_LIBRARY_ID=

# --- Mapa / estabilidade visual (cliente) ---
# true = toast «Quase lá» ao caminhar perto de uma sala (experimental).
# Omitido ou diferente de "true" = desligado: entrada só ao clicar no hotspot/polígono.
# «Depois» / fechar guardam essa zona em sessionStorage até fechar o separador.
# NEXT_PUBLIC_CAMPUS_ZONE_ENTRY_PROMPT=true
# Mapa avançado: só com valor exato "true". Ausente, "false" ou outro valor = modo simples
# (imagem + hit-boxes + HUD/menu/Live; sem polígonos, fog, walk mesh nem tooltips de zona).
# NEXT_PUBLIC_CAMPUS_ADVANCED_MAP=true
#
# QA rápido — cinema em cima do mapa avançado (manchas escuras / «chunks»):
# 1) Defina NEXT_PUBLIC_CAMPUS_ADVANCED_MAP=true e reinicie `npm run dev`.
# 2) Abra `/campus`, vá ao telão / Cine THCProce e abra o player (`isCineOpen`).
# 3) O fundo deve coincidir com o mesmo mapa antes de abrir o cinema (névoa/zonas/biome intactos).
#    O `CampusMap` não deve ramificar camadas ao cinema — só `CineDriveIn`/HUD sobrepõem (z-index maior).
# 4) Se ainda vir polígonos muito escuros, verifique `zone.color` em `src/data/campusZones.ts`
#    (cores inválidas ou quase pretas são elevadas a tom legível em `useZoneStatus`).
# HUD campus: contagem real via Supabase Presence (sempre que URL/anon existem). Sem chaves: só "Campus vivo", sem número.
# Legado (não usado pelo HUD): NEXT_PUBLIC_SHOW_ONLINE_COUNT exigia "true" para mostrar total.
# NEXT_PUBLIC_SHOW_ONLINE_COUNT=true
# Camada Pixi (partículas WebGL): por defeito DESLIGADA. Ative só quando quiser o efeito.
# NEXT_PUBLIC_CAMPUS_ENABLE_PIXI=true
# Contorno vermelho no estágio do mapa (#campus-map-stage) para depuração de camadas.
# NEXT_PUBLIC_CAMPUS_MAP_DEBUG=true
# Polígonos do catálogo `campusMapAreasCatalog` + JSON opcional em localStorage (ver docs/campus-map-areas-authoring.md).
# NEXT_PUBLIC_CAMPUS_MAP_AREAS_DEBUG=true
# Polígonos rotulados das áreas image-map (`CAMPUS_MAP_INTERACTIVE_AREAS`), modo simples.
# NEXT_PUBLIC_CAMPUS_MAP_INTERACTIVE_DEBUG=true
# `/campus` — reload total opcional (ms); por defeito desligado. Só define valor >0 se precisares (ex.: 60000); corta áudio até ao próximo play.
# NEXT_PUBLIC_CAMPUS_MAP_RELOAD_INTERVAL_MS=60000

# --- ElevenLabs (TTS servidor — nunca prefixo NEXT_PUBLIC_ na API key) ---
# Chave só servidor (Vercel → Settings → Environment Variables → Production).
# ELEVENLABS_API_KEY=
# ID da voz oficial THCProce no ElevenLabs.
# ELEVENLABS_VOICE_ID=
# Modelo opcional (omitido = eleven_multilingual_v2).
# ELEVENLABS_MODEL_ID=eleven_multilingual_v2
# Mostrar link «Voz (teste)» no header admin + página /admin/voice-test (requer sessão admin).
# NEXT_PUBLIC_CAMPUS_VOICE_TEST_PANEL=true

{
  "name": "thcproce-campus",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "node scripts/run-next-dev.cjs --check-only",
    "dev": "node scripts/run-next-dev.cjs",
    "clean": "node -e \"try{require('fs').rmSync('.next',{recursive:true,force:true});console.log('Removed .next. If npm run dev was running, STOP it completely and run dev again — otherwise manifests (e.g. middleware-manifest.json) will be missing.')}catch(e){console.error(e)}\"",
    "dev:clean": "npm run clean && npm run dev",
    "build": "prisma generate && next build",
    "start": "next start -p 3030",
    "lint": "next lint",
    "postinstall": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "node prisma/seed.cjs"
  },
  "prisma": {
    "seed": "node prisma/seed.cjs"
  },
  "dependencies": {
    "@mux/mux-player-react": "^3.13.0",
    "@prisma/client": "5.22.0",
    "@radix-ui/react-slot": "^1.2.4",
    "@sentry/nextjs": "^10.52.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.105.3",
    "@tanstack/react-query": "^5.100.9",
    "@trpc/client": "^11.17.0",
    "@trpc/react-query": "^11.17.0",
    "@trpc/server": "^11.17.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^11.11.17",
    "lucide-react": "^0.460.0",
    "next": "14.2.18",
    "next-auth": "^4.24.14",
    "pixi.js": "^8.18.1",
    "prisma": "5.22.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-player": "^2.16.1",
    "superjson": "^2.2.6",
    "tailwind-merge": "^2.5.4",
    "zod": "^4.4.3",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.4.20",
    "eslint": "^8",
    "eslint-config-next": "14.2.18",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5"
  }
}
